# Dockerignore para Scopios Medical
# Excluye archivos innecesarios del contexto de Docker

# Node modules y dependencias
node_modules/
npm-debug.log
yarn-debug.log
yarn-error.log
package-lock.json
yarn.lock

# Archivos de desarrollo
src/
public/
.vscode/
.idea/
*.log
*.swp
*.swo
*~

# Variables de entorno (NO deben estar en la imagen)
.env
.env.local
.env.development
.env.production
.env.*.local

# Git
.git/
.gitignore
.gitattributes

# Configuración de desarrollo
vite.config.ts
tsconfig.json
tsconfig.app.json
tsconfig.node.json
eslint.config.js
postcss.config.js
tailwind.config.js

# Tests
__tests__/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
coverage/

# Documentación y especificaciones
info/*.pdf
info/*.xlsx
info/*.pptx
info/*.md
CLAUDE.md
README.md
*.md

# Scripts
scripts/
migrations/

# Temporal
tmp/
temp/
*.tmp

# Sistema operativo
.DS_Store
Thumbs.db
desktop.ini

# IMPORTANTE: NO excluir estos archivos necesarios
!dist/
!nginx.conf
!nginx-site.conf
!Dockerfile
